<?xml version='1.0' encoding='utf-8'?>
<widget id="com.curb.trillboards" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>TrillboardsApp</name>
    <description>Curb Mobility Programmatic Ad Player</description>
    <author email="dev@cordova.apache.org" href="https://cordova.apache.org">Apache Cordova Team</author>
    <content src="index.html" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <access origin="*" />
    <allow-navigation href="*" />
    <platform name="android">
        <preference name="MediaPlaybackRequiresUserGesture" value="false" />
        <preference name="AllowInlineMediaPlayback" value="true" />
        <preference name="KeepRunning" value="true" />
        <preference name="Fullscreen" value="true" />
        <preference name="DisallowOverscroll" value="true" />
        <preference name="MixedContentMode" value="2" />
        <preference name="SplashScreenDelay" value="0" />
        <allow-navigation href="*" />
    </platform>
</widget>
